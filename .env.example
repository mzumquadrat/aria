# ===========================================
# Aria Personal Assistant - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# Configuration is primarily done in config.yaml
# This file contains secrets and overrides

# -------------------------------------------
# REQUIRED: Telegram Bot Token
# -------------------------------------------
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# -------------------------------------------
# REQUIRED: OpenRouter API Key
# -------------------------------------------
# Get from https://openrouter.ai
OPENROUTER_API_KEY=

# -------------------------------------------
# OPTIONAL: Telegram User ID (security)
# -------------------------------------------
# Restrict bot to your account only
# Get from @userinfobot on Telegram
TELEGRAM_USER_ID=

# -------------------------------------------
# OPTIONAL: ElevenLabs (voice features)
# -------------------------------------------
# Get from https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# STT model: scribe_v1, scribe_v1_experimental, scribe_v2
ELEVENLABS_STT_MODEL_ID=

# -------------------------------------------
# OPTIONAL: Brave Search (web search)
# -------------------------------------------
# Get from https://brave.com/search/api
BRAVE_API_KEY=

# -------------------------------------------
# OPTIONAL: Calendar Integration
# -------------------------------------------
# CalDAV (iCloud, Nextcloud, Radicale, etc.)
CALDAV_SERVER_URL=
CALDAV_USERNAME=
CALDAV_PASSWORD=
CALDAV_DEFAULT_CALENDAR=

# Google Calendar
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_DEFAULT=

# -------------------------------------------
# OPTIONAL: Subsonic Music Server
# -------------------------------------------
# For playlist management and music search
SUBSONIC_SERVER_URL=
SUBSONIC_USERNAME=
SUBSONIC_PASSWORD=

# -------------------------------------------
# OPTIONAL: Last.fm Integration
# -------------------------------------------
# For mood-based music recommendations
# Get from https://www.last.fm/api/account/create
LASTFM_API_KEY=
LASTFM_USERNAME=

# -------------------------------------------
# OPTIONAL: Database Path
# -------------------------------------------
DATABASE_PATH=

# -------------------------------------------
# OPTIONAL: Logging
# -------------------------------------------
# Set to "debug" for verbose logs
# LOG_LEVEL=info
