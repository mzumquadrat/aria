# ===========================================
# Aria Personal Assistant Configuration
# ===========================================

# -------------------------------------------
# REQUIRED: Telegram Configuration
# -------------------------------------------
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: Restrict bot to specific user (your Telegram user ID)
# Get your ID from @userinfobot on Telegram
TELEGRAM_USER_ID=

# -------------------------------------------
# REQUIRED: OpenRouter Configuration
# -------------------------------------------
# Get your API key from https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key

# Optional: Default model for completions
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4

# Optional: Fallback model if default fails
OPENROUTER_FALLBACK_MODEL=openai/gpt-4o-mini

# Optional: HTTP Referer for OpenRouter rankings
HTTP_REFERER=http://localhost:8000

# -------------------------------------------
# OPTIONAL: ElevenLabs Voice Configuration
# -------------------------------------------
# Get your API key from https://elevenlabs.io
# Enables voice message transcription and TTS responses
ELEVENLABS_API_KEY=

# Voice ID for text-to-speech (default: Rachel)
# Find voices at https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Model ID for TTS (default: multilingual v2)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# -------------------------------------------
# OPTIONAL: Brave Search Configuration
# -------------------------------------------
# Get your API key from https://brave.com/search/api
# Enables web search capability for the agent
BRAVE_API_KEY=

# API base URL (default shown)
BRAVE_API_BASE_URL=https://api.search.brave.com/res/v1

# Number of search results to return (default: 10)
BRAVE_SEARCH_COUNT=10

# -------------------------------------------
# OPTIONAL: Database Configuration
# -------------------------------------------
# Path to SQLite database file
DATABASE_PATH=./data/aria.db

# -------------------------------------------
# OPTIONAL: Logging Configuration
# -------------------------------------------
# Log level: debug, info, warn, error
LOG_LEVEL=info

# -------------------------------------------
# OPTIONAL: Shell Configuration (for skills)
# -------------------------------------------
# Comma-separated list of allowed directories
# SHELL_ALLOWED_DIRS=/home/user,/tmp

# Comma-separated list of denied directories
# SHELL_DENIED_DIRS=/etc,/root

# Comma-separated list of allowed commands
# SHELL_ALLOWED_COMMANDS=ls,cat,echo

# Comma-separated list of denied commands
# SHELL_DENIED_COMMANDS=rm,sudo

# Shell command timeout in milliseconds
# SHELL_TIMEOUT=30000

# -------------------------------------------
# OPTIONAL: Approval Configuration
# -------------------------------------------
# Auto-approve read-only operations
# APPROVAL_AUTO_APPROVE_READONLY=true

# Require approval for write operations
# APPROVAL_REQUIRE_APPROVAL_WRITE=true

# Approval timeout in seconds
# APPROVAL_TIMEOUT=300

# -------------------------------------------
# OPTIONAL: Scheduler Configuration
# -------------------------------------------
# Check interval for scheduled tasks in milliseconds
# SCHEDULER_CHECK_INTERVAL=1000

# Maximum concurrent scheduled tasks
# SCHEDULER_MAX_CONCURRENT=5
